# Urbex API
NEXT_PUBLIC_URBEX_API_URL=https://api-prod.urbex.com.co
URBEX_API_KEY=your_urbex_api_key_here

# AWS Cognito
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-2_XXXXXXXXX
NEXT_PUBLIC_COGNITO_CLIENT_ID=your_cognito_client_id_here
NEXT_PUBLIC_COGNITO_REGION=us-east-2

# AWS (server-side, solo si usas admin Cognito)
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=us-east-2

# Maps
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# Site
NEXT_PUBLIC_SITE_URL=https://www.urbex.com.co/proyectos
